auto-install-peers=false
strict-peer-dependencies=false
# Don't let pnpm auto-switch versions based on the root packageManager field.
# Corepack (Node 16.13+) is the canonical way to honor that pin on user machines,
# and this avoids a fatal self-install loop when the local pnpm is older than
# the pinned version. See: https://pnpm.io/settings#managepackagemanagerversions
manage-package-manager-versions=false
