# =============================================================
# api-server environment — copy to .env (gitignored) and fill in.
# =============================================================

# ── Admin login (DEV / TESTING ONLY) ─────────────────────────
# Server-authoritative admin entry for the AuthGate "Admin Access" button.
# DISABLED BY DEFAULT: if ADMIN_LOGIN_ENABLED is not "true", OR ADMIN_ACCESS_CODE
# is empty, every admin attempt is denied (fail closed). NEVER enable in prod.
#
#   ADMIN_LOGIN_ENABLED   must be exactly "true" to allow admin login at all.
#   ADMIN_ACCESS_CODE     the dev passcode the client must enter + the server
#                         verifies (constant-time). Keep it secret; never commit.
#   ADMIN_ALLOWED_USERNAMES  optional comma-separated allowlist (case-insensitive)
#                         e.g. "anja,dev1". If set, the username must be on it.
ADMIN_LOGIN_ENABLED=false
ADMIN_ACCESS_CODE=
ADMIN_ALLOWED_USERNAMES=

# The CLIENT must also opt in to SHOW the button (city-sandbox build env):
#   VITE_ENABLE_ADMIN_LOGIN=true
# Without it the Admin button is not rendered at all.

# ── Other existing keys (Solana / Nemo Gang) live here too, e.g.: ──
# SOLANA_RPC_URL=
# NEMOCLAW_MINT=
# NEMOCLAW_MIN_AMOUNT=
